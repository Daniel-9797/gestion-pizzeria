# ─────────────────────────────────────────────
#  PLANTILLA DE CONFIGURACIÓN
#  Copia este archivo como «.env» y rellena tus valores reales.
#  El «.env» real NUNCA se sube a git (está en .gitignore).
# ─────────────────────────────────────────────

# ── Base de datos local (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=productos_tpv
DB_USER=postgres
DB_PASSWORD=tu_password_local

# ── Copia en la nube (Neon u otro PostgreSQL). Opcional. ──
# Si dejas CLOUD_DB_HOST vacío, la sincronización se desactiva sola.
CLOUD_DB_HOST=
CLOUD_DB_PORT=5432
CLOUD_DB_NAME=
CLOUD_DB_USER=
CLOUD_DB_PASSWORD=
CLOUD_DB_SSLMODE=require

# ── Contraseñas de acceso a la app ──
APP_PASSWORD_EMPLEADO=caja123
APP_PASSWORD_MASTER=cambiame

# ── API de fútbol (football-data.org). Opcional. ──
FOOTBALL_DATA_API_TOKEN=

# ── Correo del cierre diario (Gmail SMTP). Opcional. ──
# EMAIL_PASS debe ser una "contraseña de aplicación" de Gmail (16 caracteres).
EMAIL_USER=
EMAIL_PASS=
EMAIL_DESTINO_CIERRE=
